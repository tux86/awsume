{
  "name": "awsume",
  "description": "Interactive AWS credential manager with CLI and desktop app",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tux86/awsume.git"
  },
  "author": "tux86",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cli": "bun run --cwd packages/cli start",
    "gui": "bun run --cwd packages/gui dev",
    "build": "bun run build:cli",
    "build:cli": "bun run --cwd packages/cli build",
    "lint": "eslint packages/*/src",
    "changeset": "changeset",
    "version": "changeset version",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.0.0",
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "latest",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "react-devtools-core": "^7.0.1"
  }
}
